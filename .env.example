# Discord Bot Token
# Discord Developer Portal -> Your Application -> Bot -> Reset Token
DISCORD_TOKEN=your_bot_token_here

# Client ID (Bot ID)
# Discord Developer Portal -> Your Application -> General Information -> Application ID
CLIENT_ID=your_client_id_here

# Guild ID (Sunucu ID)
# Discord'da sunucu ayarları -> Gelişmiş -> Geliştirici Modu'nu açın
# Sunucuya sağ tıklayın -> ID'yi Kopyala
GUILD_ID=your_guild_id_here

# NOT: Tüm değerleri tırnak işareti olmadan girin!